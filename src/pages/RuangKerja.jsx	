function formatSize(bytes) {
  if (!bytes) return '0 B'
  const sizes = ['B', 'KB', 'MB']
  const i = Math.min(Math.floor(Math.log(bytes) / Math.log(1024)), 2)
  return `${(bytes / Math.pow(1024, i)).toFixed(1)} ${sizes[i]}`
}

