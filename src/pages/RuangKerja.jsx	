n// Helper\nfunction formatSize(bytes) {\n  if (!bytes) return '0 B'\n  const sizes = ['B', 'KB', 'MB']\n  const i = Math.floor(Math.log(bytes) / Math.log(1024))\n  return `${(bytes / Math.pow(1024, i)).toFixed(1)} ${sizes[i]}`\n}

