# HTML - never cache, always fetch fresh
/
  Cache-Control: no-cache, no-store, must-revalidate
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; manifest-src 'self'; worker-src 'self'

/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# JS/CSS chunks - hash in filename, cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Icons
/icons/*
  Cache-Control: public, max-age=31536000, immutable

# SW - never cache (must update immediately)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Manifest
/manifest.json
  Cache-Control: no-cache, must-revalidate

# API responses - never cache
/api/*
  Cache-Control: no-store
